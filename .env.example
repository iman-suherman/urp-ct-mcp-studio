# Google Cloud ADC — run: npm run login (writes .gcloud/application_default_credentials.json)
GOOGLE_APPLICATION_CREDENTIALS=.gcloud/application_default_credentials.json
# Set by npm run login (or override here)
GCP_USER_EMAIL=
GCP_PROJECT_ID=

# Extension upload (npm run upload) — bucket defaults to ${GCP_PROJECT_ID}-ct-mcp-studio
GCS_EXTENSION_BUCKET=
GCS_LOCATION=australia-southeast1
GCS_EXTENSION_PREFIX=extensions

# Firestore plugin version registry
FIRESTORE_PLUGIN_COLLECTION=mcp_plugin_versions
FIRESTORE_PLUGIN_CATALOG=mcp_plugin_catalog

# Cloud Run registry API (npm run deploy:registry)
REGISTRY_API_SERVICE=ct-mcp-registry-api

# Website (npm run deploy:website)
WEBSITE_SERVICE=ct-mcp-website
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8W3G7DCQGH
NEXT_PUBLIC_REGISTRY_API_URL=https://ct-mcp-registry.suherman.net
NEXT_PUBLIC_PLUGIN_ID=ct-mcp-studio
NEXT_PUBLIC_DOWNLOAD_BASE_URL=https://ct-mcp-download.suherman.net/downloads
PUBLIC_DOWNLOAD_BASE_URL=https://ct-mcp-download.suherman.net/downloads
WEBSITE_BASE_URL=https://ct-mcp.suherman.net
DEFAULT_PLUGIN_ID=ct-mcp-studio
